 =?UTF-8?q?=E5=BD=B1=E3=81=A7=E3=80=8C=E7=B1=B3=E7=B2=92=E3=80=8D=E5=8C=96?=
 =?UTF-8?q?=E3=81=99=E3=82=8B=E5=95=8F=E9=A1=8C=E3=81=AE=E5=8E=9F=E5=9B=A0?=
 =?UTF-8?q?=E5=88=87=E3=82=8A=E5=88=86=E3=81=91=E7=94=A8=E3=83=87=E3=83=90?=
 =?UTF-8?q?=E3=83=83=E3=82=B0=E8=A1=A8=E7=A4=BA=E3=82=92=E8=BF=BD=E5=8A=A0?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- js/character.js: MMDCharacter/SpriteCharacterにgetHeight()を追加。
  unitToMeter*scaleが反映された実際のワールド空間での高さ(m)を返す。
- main.js: ?debug=1のGROUND Confidenceオーバーレイに、現在のZ距離(m)と
  キャラクターの実寸高さ(m)を併記。
- index.html: 対応するDOM要素(#ground-debug-distance/-height)を追加。

背景: 実機写真で、キャラクターが想定より極端に小さく写る現象が報告された。
FOV42度・既定Z=-3.2mの物理計算では画面高さの約63%を占めるはずだが、
写真では十数%程度しかなく、実際のZが約15〜20m相当まで動いているか、
unitToMeter自体のスケール計算に問題があるかの2つの仮説が考えられる。
数値を当てずっぽうで変えず、実測できるデバッグ表示を追加して次回の
実機確認で原因を確定させる方針とした(CONSTRAINTS.md 5節に準拠)。

node --check通過、トップレベルconst/let重複宣言なし、
index.html/main.js間のID整合性を確認済み。
---
 index.html      |  8 +++++++-
 js/character.js | 10 ++++++++++
 main.js         | 10 ++++++++++
 3 files changed, 27 insertions(+), 1 deletion(-)

diff --git a/index.html b/index.html
index abadd39..07dc5eb 100644
--- a/index.html
+++ b/index.html
@@ -108,11 +108,17 @@
 </div>
 
 <!-- 床推定デバッグ表示(Ground Confidence Engine)：通常は非表示。
-     ?debug=1 か localStorageのoshi_debug_groundで有効化できる。 -->
+     ?debug=1 か localStorageのoshi_debug_groundで有効化できる。
+     「遠距離で米粒のように小さい」問題の原因切り分けのため、Z距離と
+     キャラクターの実寸高さ(m)も併記する(2026/07診断用に追加)。 -->
 <div id="ground-debug-overlay">
   <div class="gd-label">GROUND</div>
   <div class="gd-label">Confidence</div>
   <div id="ground-debug-value">--%</div>
+  <div class="gd-label" style="margin-top:6px">DISTANCE</div>
+  <div id="ground-debug-distance">-- m</div>
+  <div class="gd-label" style="margin-top:6px">CHAR HEIGHT</div>
+  <div id="ground-debug-height">-- m</div>
 </div>
 
 <div id="loading-overlay">
diff --git a/js/character.js b/js/character.js
index 1491ea2..0bfba1a 100644
--- a/js/character.js
+++ b/js/character.js
@@ -106,6 +106,15 @@ export class MMDCharacter {
     const box = new THREE.Box3().setFromObject(this.root);
     return Math.max(0.4, box.max.x - box.min.x);
   }
+  /**
+   * 診断用: 現在のroot.scale(unitToMeter*scale)が反映された状態での、
+   * ワールド空間での実際の高さ(m)を返す。unitToMeter/scaleの計算が
+   * 意図通りかを実測値として確認するために使う(例: main.jsのデバッグ表示)。
+   */
+  getHeight() {
+    const box = new THREE.Box3().setFromObject(this.root);
+    return box.max.y - box.min.y;
+  }
   setExpression(key) {
     const preset = this.expressions[key];
     if (!preset) return;
@@ -292,6 +301,7 @@ export class SpriteCharacter {
   }
   getFootY() { return this.root.position.y; }
   getWidth() { return this.root.scale.x; }
+  getHeight() { return this.root.scale.y; }
   setExpression() {}
   setPose() {}
   getCurrentPoseBoneNames() { return []; }
diff --git a/main.js b/main.js
index d7c7f4d..3961dbf 100644
--- a/main.js
+++ b/main.js
@@ -63,6 +63,8 @@ const groundCalibScreen = document.getElementById('ground-calib-screen');
 const groundCalibOkBtn = document.getElementById('ground-calib-ok-btn');
 const groundDebugOverlay = document.getElementById('ground-debug-overlay');
 const groundDebugValue = document.getElementById('ground-debug-value');
+const groundDebugDistance = document.getElementById('ground-debug-distance');
+const groundDebugHeight = document.getElementById('ground-debug-height');
 
 let poseToastTimer = null;
 function showPoseToast(text) {
@@ -986,6 +988,14 @@ function animate() {
   }
   if (DEBUG_GROUND && groundDebugValue) {
     groundDebugValue.textContent = `${Math.round(ground.confidence * 100)}%`;
+    if (groundDebugDistance) {
+      const distanceM = Math.abs(placement.z - camera.position.z);
+      groundDebugDistance.textContent = `${distanceM.toFixed(2)} m`;
+    }
+    if (groundDebugHeight && activeCharacter) {
+      const heightM = activeCharacter.getHeight();
+      groundDebugHeight.textContent = `${heightM.toFixed(2)} m`;
+    }
   }
 
   if (activeCharacter) activeCharacter.update(dt);
-- 
